const sectionsEl = document.getElementById('sections');
const emptyEl = document.getElementById('empty');
const cntEl = document.getElementById('cnt');

function render(filterFn) {
  sectionsEl.innerHTML = '';
  let count = 0;

  let i = 0;
  while (i < BLOCKS.length) {
    const b = BLOCKS[i];
    if (b.type !== 'head') { i++; continue; }

    // 이 섹션의 아이템 수집
    const secItems = [];
    let j = i + 1;
    while (j < BLOCKS.length && BLOCKS[j].type !== 'head') {
      if (filterFn(BLOCKS[j])) secItems.push(BLOCKS[j]);
      j++;
    }

    if (secItems.length > 0) {
      const sec = document.createElement('div');
      sec.className = 'section';
      sec.id = 'sec-' + i;

      const hd = document.createElement('div');
      hd.className = 'sec-head';
      hd.textContent = b.text;
      sec.appendChild(hd);

      const cloud = document.createElement('div');
      cloud.className = 'cloud';

      secItems.forEach(item => {
        count++;
        const chip = document.createElement('span');
        chip.id = 'item-' + item.n;

        if (item.type === 'v') {
          chip.className = 'chip chip-v' + item.val;
          const curVal = item.val;
          const mvHtml = item.multiVal
            ? '<span class="mv-badges">' + item.multiVal.map(v => {
                const dim = v !== curVal ? ' mv-dim' : '';
                return `<span class="mv-b mv-${v}${dim}">${v}가</span>`;
              }).join('') + '</span>'
            : '';
          chip.innerHTML = `<span class="n">${item.n}</span><span class="word">${item.v}</span>${mvHtml}`;
        } else {
          chip.className = 'chip chip-cx';
          chip.innerHTML = `<span class="n">${item.n}</span><span class="word">${item.formula}</span>`;
        }
        cloud.appendChild(chip);
      });

      sec.appendChild(cloud);
      sectionsEl.appendChild(sec);
    }

    i = j;
  }

  cntEl.textContent = count;
  emptyEl.style.display = count === 0 ? 'block' : 'none';
}

render(() => true);

