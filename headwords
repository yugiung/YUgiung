    --surface: #fff;
    --border: #e8e4dc;
    --ink: #1a1a18;
    --muted: #999;
    --faint: #f4f2ee;
    --v1: #1d4ed8;
    --v2: #15803d;
    --v3: #b45309;
    --cx: #7c3aed;
