  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    line-height: 1.6;
  }

  /* 헤더 */
  header {
    border-bottom: 2px solid var(--ink);
    padding: 1.5rem 2.5rem 1.2rem;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  header h1 {
    font-family: 'Fira Code', monospace;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  header p {
    font-size: 0.72rem;
    color: var(--muted);
  }
  .hdr-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .search-input {
    font-family: 'Fira Code', monospace;
    font-size: 0.72rem;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--ink);
    border-radius: 4px;
    outline: none;
    width: 200px;
  }
  .search-input:focus { border-color: var(--ink); }
  .search-input::placeholder { color: var(--muted); }
  .cnt {
    font-family: 'Fira Code', monospace;
    font-size: 0.68rem;
    color: var(--muted);
  }

  /* 범례 */
  .legend {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.6rem 2.5rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    gap: 1.2rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .legend-item {
    display: flex; align-items: center; gap: 0.3rem;
    font-size: 0.68rem; color: var(--muted);
  }
  .dot {
    width: 8px; height: 8px; border-radius: 50%;
  }

  /* 본문 */
  .body {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2.5rem 3rem;
  }

  /* 섹션 */
  .section { margin-top: 2rem; }

  .sec-head {
    font-family: 'Fira Code', monospace;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.4rem;
    margin-bottom: 0.8rem;
  }

  /* 태그 클라우드 — 결합가 + 구문 모두 동일 */
  .cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    border: 1px solid transparent;
    cursor: default;
    transition: opacity 0.1s;
  }
  .chip:hover { opacity: 0.7; }

  .chip .n {
    font-family: 'Fira Code', monospace;
    font-size: 0.55rem;
    color: var(--muted);
    margin-right: 0.1rem;
  }

  .chip .word {
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  /* 결합가 색상 */
  .chip-v1 {
    background: #eff6ff;
    border-color: #bfdbfe;
  }
  .chip-v1 .word { color: var(--v1); }

  .chip-v2 {
    background: #f0fdf4;
    border-color: #bbf7d0;
  }
  .chip-v2 .word { color: var(--v2); }

  .chip-v3 {
    background: #fffbeb;
    border-color: #fde68a;
  }
  .chip-v3 .word { color: var(--v3); }

  /* 구문문법 색상 */
  .mv-badges { display:inline-flex; gap:2px; margin-left:3px; vertical-align:middle; }
  .mv-b { font-size:0.48rem; font-weight:bold; padding:1px 4px; border-radius:2px; border:1px solid; }
  .mv-1 { background:#0d1f33; color:#5a9fd4; border-color:#1e3a5f; }
  .mv-2 { background:#0d1f0d; color:#5ab87a; border-color:#1a3a1a; }
  .mv-3 { background:#1f1505; color:#c8963c; border-color:#3a2a10; }
  .mv-dim { opacity:0.35; }
  .chip-cx {
    background: #faf5ff;
    border-color: #e9d5ff;
  }
  .chip-cx .word {
    color: var(--cx);
    font-family: 'Fira Code', monospace;
    font-size: 0.78rem;
    font-weight: 400;
  }

  .hidden { display: none !important; }

  .empty {
    padding: 3rem;
    text-align: center;
    font-family: 'Fira Code', monospace;
    font-size: 0.75rem;
    color: var(--muted);
    display: none;
  }
</style>
